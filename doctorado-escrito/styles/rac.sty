 \twoinmar
 \centerline{\large\bf Lista de tablas}
 \vspace{0.7in}
 \begin{singlespace}
  \@starttoc{lot}\if@restonecol\twocolumn\fi
  % \par en lugar de \hfill\newline (ver \listoffigures).
  \addtocontents{lot}{\noindent\underline{\bf Tabla}\protect\par}
 \end{singlespace}
}

\def\listofmaps{%
 \newpage
 \addcontentsline{toc}{chapter}{Lista de mapas}
 \@restonecolfalse\if@twocolumn\@restonecoltrue\onecolumn\fi
 \hbox{ }
 \twoinmar
 \centerline{\large\bf Lista de mapas}
 \vspace{0.7in}
 \begin{singlespace}
  \@starttoc{lom}\if@restonecol\twocolumn\fi
  \addtocontents{lom}{\noindent\underline{\bf Map}\hfill\rm\protect\newline}
 \end{singlespace}
}

\def\listofappendices{%
 \newpage
 \addcontentsline{toc}{chapter}{Lista de ap\'endices}
 \@restonecolfalse\if@twocolumn\@restonecoltrue\onecolumn\fi
 \hbox{ }
